<?xml version="1.0" encoding="UTF-8"?>
<!--
  Task XML Template - Individual task file (<num>_task.xml)
  Generated by zord:generate-action-plan
  Reference: TASK_COMPLETENESS_MODEL.md
-->
<task>
  <metadata>
    <id>{{TASK_ID}}</id>
    <title>{{TASK_TITLE}}</title>
    <priority>{{P0|P1|P2}}</priority>
    <sprint>{{SPRINT_NUMBER}}</sprint>
    <type>{{implementation|integration|testing|documentation|health_check}}</type>
    <status>pending</status>
    <!-- Lista de task IDs que devem estar completas antes desta task iniciar (ex: "00,04") -->
    <dependencies>{{TASK_IDS_OR_EMPTY}}</dependencies>
    <!-- Stage level do execution_plan em tasks.xml (para referencia rapida) -->
    <execution_stage>{{STAGE_LEVEL}}</execution_stage>
  </metadata>

  <context>
    <description>{{TASK_DESCRIPTION}}</description>
    <linked_documents>
      <doc>{{TECHSPEC_PATH}}#{{SECTION}}</doc>
    </linked_documents>
  </context>

  <scope>
    <in_scope>
      <item>{{IN_SCOPE_ITEM}}</item>
    </in_scope>
    <out_of_scope>
      <item>{{OUT_OF_SCOPE_ITEM}}</item>
    </out_of_scope>
  </scope>

  <implementation>
    <files_to_modify>
      <file>{{FILE_PATH}}</file>
    </files_to_modify>
    <steps>
      <step>{{STEP_DESCRIPTION}}</step>
    </steps>
  </implementation>

  <acceptance_criteria>
    <criterion>{{CRITERION_DESCRIPTION}}</criterion>
  </acceptance_criteria>

  <!--
    Paralelizacao: metadados para validacao de conflitos (added by zord:enrich-tasks)

    <properties>
      <idempotent>true|false</idempotent>
      <estimated_cost>1-10</estimated_cost>
      <serial_only>true|false</serial_only>  <!-- true se resources nao declarados -->
    </properties>

    <resources>
      <resource path="{{FILE_PATH}}" mode="read|write|read-write" />
      <resource group="{{RESOURCE_GROUP}}" mode="read|write|read-write" />  <!-- ex: repo:lockfile, db:migrations -->
    </resources>
  -->

  <!--
    Optional tags (added by zord:enrich-tasks when needed):

    <discovery>
      <goal>{{DISCOVERY_GOAL}}</goal>
      <commands><command>{{COMMAND}}</command></commands>
      <stop_criteria>{{STOP_CRITERIA}}</stop_criteria>
      <artifacts><artifact>{{ARTIFACT}}</artifact></artifacts>
    </discovery>

    <decisions>
      <decision id="DEC-01">
        <statement>{{DECISION}}</statement>
        <source>{{DOC_REF}}</source>
        <reason>{{REASON}}</reason>
      </decision>
    </decisions>

    <validation>
      <test_plan>
        <unit>{{UNIT_TESTS}}</unit>
        <integration>{{INTEGRATION_TESTS}}</integration>
      </test_plan>
      <commands><command>{{VALIDATION_COMMAND}}</command></commands>
      <expected_outcomes><outcome>{{EXPECTED_OUTCOME}}</outcome></expected_outcomes>
    </validation>

    <assumptions>
      <assumption>{{ASSUMPTION}}</assumption>
    </assumptions>

    <open_questions>
      <question id="Q1">
        <text>{{QUESTION}}</text>
        <blocking_reason>{{BLOCKING_REASON}}</blocking_reason>
      </question>
    </open_questions>

    <non_functional_requirements>
      <security>{{SECURITY_REQ}}</security>
      <performance>{{PERF_REQ}}</performance>
      <observability>{{OBS_REQ}}</observability>
    </non_functional_requirements>

    <rollout>
      <strategy>{{ROLLOUT_STRATEGY}}</strategy>
      <steps><step>{{ROLLOUT_STEP}}</step></steps>
    </rollout>

    <rollback>
      <strategy>{{ROLLBACK_STRATEGY}}</strategy>
    </rollback>

    <enriched_by_consensus>
      <gap_identified severity="{{SEVERITY}}" dimension="{{D1-D8}}">{{GAP}}</gap_identified>
      <filled_information>{{INFO}}</filled_information>
      <source>{{SOURCE}}</source>
      <timestamp>{{ISO_TIMESTAMP}}</timestamp>
      <model>{{MODEL}}</model>
    </enriched_by_consensus>
  -->
</task>
