<?xml version="1.0" encoding="UTF-8"?>
<!--
  Tasks XML Template - Master file (tasks.xml)
  Generated by zord:generate-action-plan
  Reference: TASK_COMPLETENESS_MODEL.md
-->
<tasks>
  <metadata>
    <title>{{PLAN_TITLE}}</title>
    <generated_at>{{ISO_TIMESTAMP}}</generated_at>
    <source>{{ANALYSIS_SOURCE}}</source>
    <model>{{MODEL_USED}}</model>
    <repo_context>
      <root>{{REPO_ROOT}}</root>
      <branch>{{BRANCH}}</branch>
      <commit>{{COMMIT}}</commit>
      <stack>{{STACK}}</stack>
    </repo_context>
  </metadata>

  <summary>
    <total_tasks>{{N}}</total_tasks>
    <by_priority>
      <p0>{{COUNT}}</p0>
      <p1>{{COUNT}}</p1>
      <p2>{{COUNT}}</p2>
    </by_priority>
    <by_sprint>
      <sprint id="0">{{TASK_IDS}}</sprint>
      <sprint id="1">{{TASK_IDS}}</sprint>
    </by_sprint>
  </summary>

  <task_list>
    <task_ref id="00" file="00_task.xml" title="Health check baseline" priority="P0" type="health_check" />
    <task_ref id="01" file="01_task.xml" title="{{TITLE}}" priority="{{PRIORITY}}" type="{{TYPE}}" />
  </task_list>

  <dependencies>
    <dependency from="01" to="00" type="blocks" />
  </dependencies>

  <execution_plan>
    <!--
      PLANO DE EXECUCAO: Stages sequenciais, tasks em paralelo dentro de cada stage.
      Regras: Stage N so inicia apos TODAS as tasks do stage N-1 terminarem com sucesso.
      Gerador deve calcular levels baseado no grafo de dependencias (topological sort).
    -->
    <stage level="0" fail_fast="true">
      <!-- Tasks sem dependencias (ex: Task 00 baseline) -->
      <task_ref id="00" />
    </stage>
    <stage level="1" fail_fast="true">
      <!-- Tasks que dependem apenas do level 0 -->
      <task_ref id="01" />
      <task_ref id="02" />
    </stage>
    <stage level="2" fail_fast="true">
      <!-- Tasks que dependem de tasks do level 1 -->
      <task_ref id="03" />
    </stage>
  </execution_plan>

  <!--
    Added by zord:enrich-tasks after validation:

    <validation_status>
      <validated>true</validated>
      <enriched_via_consensus>true</enriched_via_consensus>
      <gaps_identified>{{N}}</gaps_identified>
      <gaps_filled>{{N}}</gaps_filled>
      <task_statuses>
        <task id="00" status="READY" score="1.00" />
        <task id="01" status="READY" score="0.92" />
      </task_statuses>
    </validation_status>
  -->
</tasks>
