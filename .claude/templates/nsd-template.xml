<?xml version="1.0" encoding="UTF-8"?>
<!--
  🎮 Narrative Structure Document (NSD) - Template XML
  Template para criação de documentos NSD de Fluxo de Cenas

  Uso:
  1. Copie este template
  2. Substitua os valores entre [colchetes] pelas informações específicas da quest
  3. Remova os comentários conforme necessário
  4. Exporte para Markdown para o formato final

  Histórico de Versões:
  - v1.1: Adicionada seção input_needs para rastrear decisões pendentes
    * Inspirado no techspec-template.xml do projeto
    * Kinds adaptados para contexto narrativo/quests
  - v1.0: Template base criado a partir de 3 NSDs existentes
    * semifinal.NSD.fluxo-cenas.md
    * fim-de-jogo.NSD.fluxo-cenas.md
    * primeiro-contrato.NSD.fluxo-cenas.md
-->
<nsd:document xmlns:nsd="https://coreto.projectX/nsd/schema/v1"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="https://coreto.projectX/nsd/schema/v1 nsd-schema.xsd">

  <!-- ========================================
       1️⃣ RESUMO GERAL (Checkpoint 0)
       ======================================== -->
  <nsd:checkpoint id="0" title="Resumo Geral" status="[pending|completed]">
    <nsd:metadata>
      <nsd:questName>[Nome da Quest]</nsd:questName>
      <nsd:campaignImportance>[Main | Main + Tutorial | Side | Optional]</nsd:campaignImportance>
      <nsd:controlVariable>
        <nsd:id>[ número da variável ]</nsd:id>
        <nsd:name>[ nome da variável ]</nsd:name>
      </nsd:controlVariable>
      <nsd:narrativeArc>[ Arco Narrativo - ex: Ato I — Mundo Comum ]</nsd:narrativeArc>
      <nsd:previousQuest>[ Nome da Quest anterior ou "Nenhuma" ]</nsd:previousQuest>
      <nsd:version>[ versão do documento ]</nsd:version>
      <nsd:lastUpdated>[ AAAA-MM-DD ]</nsd:lastUpdated>
      <nsd:author>[ Autor do documento ]</nsd:author>

    </nsd:metadata>

    <!-- ========================================
         INPUT_NEEDS - Questões que precisam de resposta
         Use esta seção para documentar decisões pendentes
         ======================================== -->
    <nsd:inputNeeds>
      <!-- Exemplo de necessidade de entrada narrativa -->
      <nsd:need id="[NEED_ID_1]"
                kind="[narrative|character|gameplay|pacing|dialogue|art|sound|technical|continuity|product]"
                priority="[blocker|non_blocker]"
                status="[open|answered|waived]">
        <nsd:question>[ Descrição da decisão ou questão que precisa ser respondida ]</nsd:question>

        <nsd:options>
          <nsd:option id="A">[ Descrição da opção A ]</nsd:option>
          <nsd:option id="B">[ Descrição da opção B ]</nsd:option>
          <nsd:option id="C">[ Descrição da opção C ]</nsd:option>
        </nsd:options>

        <nsd:defaultAssumption option_id="[A|B|C]">[ Assumir esta opção se não houver resposta ]</nsd:defaultAssumption>

        <nsd:impact>
          <nsd:if option_id="A">[ Impacto narrativo/jogabilidade se escolher A ]</nsd:if>
          <nsd:if option_id="B">[ Impacto narrativo/jogabilidade se escolher B ]</nsd:if>
          <nsd:if option_id="C">[ Impacto narrativo/jogabilidade se escolher C ]</nsd:if>
        </nsd:impact>

        <nsd:neededBy>[ before_writing | before_implementation | before_release ]</nsd:neededBy>
        <nsd:owner>[ writer | designer | developer | artist | sound_designer | user ]</nsd:owner>

        <nsd:trace>
          <nsd:checkpointRef>[ 0 | 1 | 2 ]</nsd:checkpointRef>
          <nsd:sceneRef>[ ID da cena afetada ]</nsd:sceneRef>
          <nsd:beatRef>[ ID do beat afetado ]</nsd:beatRef>
        </nsd:trace>
      </nsd:need>

      <!-- Adicionar mais needs conforme necessário -->
    </nsd:inputNeeds>

    <nsd:narrativeCore>
      <nsd:centralConflict>
        <nsd:description>[ Descrição do conflito central da quest ]</nsd:description>
        <nsd:protagonistVs>[ Protagonista ] vs [ Antagonista/Força Opositora ]</nsd:protagonistVs>
      </nsd:centralConflict>

      <nsd:narrativeObjective>
        <nsd:global>[ Objetivo narrativo global - o que essa quest deve alcançar ]</nsd:global>
        <nsd:emotionalTarget>[ Qual emoção deve ser evocada no jogador ]</nsd:emotionalTarget>
      </nsd:narrativeObjective>

      <nsd:premise>
        <nsd:brief>[ Premissa resumida em 1-2 parágrafos ]</nsd:brief>
        <nsd:full>[ Resumo completo da quest ]</nsd:full>
      </nsd:premise>
    </nsd:narrativeCore>

    <nsd:locations>
      <!-- Lista de locais principais onde a quest ocorre -->
      <nsd:location id="[LOC_ID_1]">
        <nsd:name>[ Nome do Local ]</nsd:name>
        <nsd:mapId>[ Mapa RPG Maker - ex: 006 ]</nsd:mapId>
        <nsd:description>[ Descrição breve ]</nsd:description>
      </nsd:location>
      <!-- Adicionar mais locais conforme necessário -->
    </nsd:locations>

    <nsd:characters>
      <!-- Lista de NPCs e personagens principais -->
      <nsd:character id="[CHAR_ID_1]" role="[protagonist|antagonist|npc|mentor]">
        <nsd:name>[ Nome do Personagem ]</nsd:name>
        <nsd:roleInQuest>[ Papel específico nesta quest ]</nsd:roleInQuest>
        <nsd:importance>[ Principal | Secundário | Cameo ]</nsd:importance>
      </nsd:character>
      <!-- Adicionar mais personagens conforme necessário -->
    </nsd:characters>

    <nsd:mechanics>
      <!-- Mecânicas de gameplay introduzidas nesta quest -->
      <nsd:mechanic id="[MECH_ID_1]">
        <nsd:name>[ Nome da Mecânica ]</nsd:name>
        <nsd:type>[ Tutorial | Reforço | Novo ]</nsd:type>
        <nsd:description>[ Descrição de como é ensinada/aplicada ]</nsd:description>
      </nsd:mechanic>
    </nsd:mechanics>
  </nsd:checkpoint>

  <!-- ========================================
       2️⃣ PRÉ-CONDICOES NARRATIVAS (Checkpoint 1)
       ======================================== -->
  <nsd:checkpoint id="1" title="Pré-condições Narrativas" status="[pending|completed]">
    <nsd:prerequisites>
      <nsd:flagsAndDecisions>
        <nsd:flag id="[FLAG_ID_1]">
          <nsd:description>[ Descrição da flag ou decisão anterior necessária ]</nsd:description>
          <nsd:source>[ Quest ou evento que originou a flag ]</nsd:source>
          <nsd:required>[ true | false ]</nsd:required>
        </nsd:flag>
      </nsd:flagsAndDecisions>

      <nsd:protagonistState>
        <nsd:emotional>[ Estado emocional do protagonista no início da quest ]</nsd:emotional>
        <nsd:physical>[ Estado físico - ferido, cansado, etc. ]</nsd:physical>
        <nsd:mental>[ Estado mental - focado, confuso, determinado, etc. ]</nsd:mental>
      </nsd:protagonistState>

      <nsd:limitations>
        <nsd:blockage id="[BLOCK_ID_1]">
          <nsd:type>[ Mapa | Item | Habilidade | Tempo ]</nsd:type>
          <nsd:description>[ Descrição da limitação ou bloqueio ]</nsd:description>
          <nsd:duration>[ Temporário | Permanente | Até evento ]</nsd:duration>
        </nsd:blockage>
      </nsd:limitations>
    </nsd:prerequisites>
  </nsd:checkpoint>

  <!-- ========================================
       3️⃣ FLUXO VISUAL DE CENAS (Checkpoint 2)
       ======================================== -->
  <nsd:checkpoint id="2" title="Fluxo Visual de Cenas" status="[pending|completed]">

    <!-- Tabela de Cenas - Visão geral -->
    <nsd:scenesOverview>
      <nsd:scene id="1">
        <nsd:name>[ Nome da Cena ]</nsd:name>
        <nsd:chronology>[ Ordem dos eventos em formato textual ]</nsd:chronology>
        <nsd:premise>[ Premissa resumida da cena ]</nsd:premise>
      </nsd:scene>
      <!-- Adicionar mais cenas conforme necessário -->
    </nsd:scenesOverview>

    <!-- Árvore de Cenas (opcional - formato ASCII) -->
    <nsd:sceneTree format="ascii">
      <nsd:text>
        <![CDATA[
        Quest: [Nome da Quest]
         ├── Cena 1: [Nome da Primeira Cena]
         │      ├── Beat 1: [Nome do Beat]
         │      ├── Beat 2: [Nome do Beat]
         │      └── ...
         ├── Cena 2: [Nome da Segunda Cena]
         │      └── ...
         └── ...
        ]]>
      </nsd:text>
    </nsd:sceneTree>

    <!-- Detalhamento por Cena com Beats -->
    <nsd:scenesDetailed>
      <nsd:scene id="1">
        <nsd:name>[ Nome da Cena ]</nsd:name>
        <nsd:mapId>[ Mapa RPG Maker onde ocorre - ex: 006 ]</nsd:mapId>

        <nsd:beats>
          <nsd:beat id="A">
            <nsd:title>[ Título do Beat ]</nsd:title>
            <nsd:premise>[ Premissa resumida do beat - o que acontece ]</nsd:premise>
            <nsd:type>[ 🎬 (Cutscene) | 🎮 (Gameplay/Jogável) | 🎮📝 (Tutorial) ]</nsd:type>
            <nsd:details>
              <!-- Detalhes adicionais opcionais -->
              <nsd:dialogueRefs>[ Referências a diálogos, se aplicável ]</nsd:dialogueRefs>
              <nsd:music>[ Música/BGM específico ]</nsd:music>
              <nsd:soundEffects>[ Efeitos sonoros importantes ]</nsd:soundEffects>
              <nsd:cameraMovement>[ Movimentos de câmera se houver ]</nsd:cameraMovement>
              <nsd:triggerConditions>[ Condições para disparar o beat ]</nsd:triggerConditions>
            </nsd:details>
          </nsd:beat>

          <!-- Adicionar mais beats conforme necessário -->
        </nsd:beats>

        <!-- Decisões do Jogador nesta cena (opcional) -->
        <nsd:playerDecisions>
          <nsd:decision id="DEC_1">
            <nsd:prompt>[ Pergunta ou situação de escolha ]</nsd:prompt>
            <nsd:options>
              <nsd:option id="A">
                <nsd:text>[ Texto da opção ]</nsd:text>
                <nsd:consequence>[ Consequência imediata ]</nsd:consequence>
                <nsd:longTermEffect>[ Efeito a longo prazo, se houver ]</nsd:longTermEffect>
              </nsd:option>
              <nsd:option id="B">
                <nsd:text>[ Texto da opção ]</nsd:text>
                <nsd:consequence>[ Consequência imediata ]</nsd:consequence>
                <nsd:longTermEffect>[ Efeito a longo prazo, se houver ]</nsd:longTermEffect>
              </nsd:option>
            </nsd:options>
          </nsd:decision>
        </nsd:playerDecisions>
      </nsd:scene>

      <!-- Adicionar mais cenas conforme necessário -->
    </nsd:scenesDetailed>
  </nsd:checkpoint>

  <!-- ========================================
       4️⃣ REFERÊNCIAS E RECURSOS (Opcional)
       ======================================== -->
  <nsd:checkpoint id="3" title="Referências e Recursos" status="[pending|completed]">
    <nsd:references>
      <nsd:dialogueFiles>
        <nsd:file>[ Caminho para arquivo de diálogos ]</nsd:file>
      </nsd:dialogueFiles>
      <nsd:conceptArt>
        <nsd:asset>[ Caminho para arte conceitual ]</nsd:asset>
      </nsd:conceptArt>
      <nsd:relatedDocs>
        <nsd:doc>[ Documentos relacionados - GDD, ADRs, etc. ]</nsd:doc>
      </nsd:relatedDocs>
    </nsd:references>

    <nsd:notes>
      <!-- Notas adicionais para desenvolvedores -->
      <nsd:note category="[technical|narrative|art|sound]">
        <nsd:content>[ Conteúdo da nota ]</nsd:content>
        <nsd:priority>[ Alta | Média | Baixa ]</nsd:priority>
      </nsd:note>
    </nsd:notes>
  </nsd:checkpoint>

  <!-- ========================================
       METADADOS DE CONTROLE
       ======================================== -->
  <nsd:controlMetadata>
    <nsd:totalScenes>[ Número total de cenas ]</nsd:totalScenes>
    <nsd:totalBeats>[ Número total de beats ]</nsd:totalBeats>
    <nsd:estimatedPlaytime>[ Tempo estimado de gameplay - ex: 15-20 min ]</nsd:estimatedPlaytime>
    <nsd:complexityLevel>[ Baixa | Média | Alta ]</nsd:complexityLevel>
    <nsd:dependencies>
      <nsd:dependency type="[quest|item|flag]">[ Dependência específica ]</nsd:dependency>
    </nsd:dependencies>
    <nsd:outputs>
      <nsd:output type="[flag|item|relationship|reputation]">
        <nsd:name>[ Nome do output ]</nsd:name>
        <nsd:value>[ Valor ou estado resultante ]</nsd:value>
      </nsd:output>
    </nsd:outputs>
  </nsd:controlMetadata>

</nsd:document>
