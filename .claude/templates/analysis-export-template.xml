<?xml version="1.0" encoding="UTF-8"?>
<!--
  Analysis Export Template
  Generated by zord commands: code-health, test-health, test-diagnose
-->
<analysis>
  <metadata>
    <version>1.0</version>
    <command>{{code-health|test-health|test-diagnose}}</command>
    <timestamp>{{ISO_TIMESTAMP}}</timestamp>
    <repo_context>
      <root>{{REPO_ROOT}}</root>
      <branch>{{BRANCH}}</branch>
      <commit>{{COMMIT}}</commit>
      <stack>{{STACK}}</stack>
    </repo_context>
  </metadata>

  <scan_summary>
    <files_scanned>{{N}}</files_scanned>
    <layers>
      <layer>{{LAYER_NAME}}</layer>
    </layers>
    <scope>{{SCOPE}}</scope>
  </scan_summary>

  <findings>
    <finding id="{{ID}}" severity="critical|high|medium|low" category="{{CATEGORY}}">
      <description>{{DESCRIPTION}}</description>
      <evidence>{{EVIDENCE}}</evidence>
      <recommendation>{{RECOMMENDATION}}</recommendation>
    </finding>
  </findings>

  <scores>
    <overall>{{0-10}}</overall>
    <by_category>
      <category name="{{CATEGORY_NAME}}">{{0-10}}</category>
    </by_category>
  </scores>
</analysis>
