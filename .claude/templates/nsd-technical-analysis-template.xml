<?xml version="1.0" encoding="UTF-8"?>
<!--
  NSD Technical Analysis Template for RPG Maker MZ

  Este template auxilia na análise técnica completa para implementação de NSDs
  no projeto Daratrine - A Origem, focando em prevenção de conflitos e
  estabilidade do jogo.

  Histórico de Versões:
  - v1.0: Template inicial criado a partir de brainstorm colaborativo
    Data: 2026-02-16
    Autor: Edney + AI Assistant
-->
<nsd:technicalAnalysis xmlns:nsd="https://coreto.projectX/nsd/technical/v1"
                       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                       xsi:schemaLocation="https://coreto.projectX/nsd/technical/v1 nsd-technical-analysis.xsd">

  <!-- ========================================
       1️⃣ METADATA (Obrigatório)
       ======================================== -->
  <nsd:metadata>
    <nsd:documentInfo>
      <nsd:templateVersion>1.0</nsd:templateVersion>
      <nsd:creationDate>{{ISO_DATE}}</nsd:creationDate>
      <nsd:lastUpdated>{{ISO_DATE}}</nsd:lastUpdated>
      <nsd:status>draft|in_review|approved|implemented|archived</nsd:status>
    </nsd:documentInfo>

    <nsd:nsdReference>
      <nsd:filePath>{{PATH_TO_NSD_XML}}</nsd:filePath>
      <nsd:questName>{{QUEST_NAME}}</nsd:questName>
      <nsd:checkpointId>{{CHECKPOINT_ID}}</nsd:checkpointId>
      <nsd:checkpointTitle>{{CHECKPOINT_TITLE}}</nsd:checkpointTitle>
    </nsd:nsdReference>

    <nsd:team>
      <nsd:author>{{AUTHOR_NAME}}</nsd:author>
      <nsd:implementer>{{IMPLEMENTER_NAME}}</nsd:implementer>
      <nsd:reviewer>{{REVIEWER_NAME}}</nsd:reviewer>
    </nsd:team>

    <nsd:repoContext>
      <nsd:root>{{REPO_ROOT}}</nsd:root>
      <nsd:branch>{{BRANCH}}</nsd:branch>
      <nsd:commit>{{COMMIT_HASH}}</nsd:commit>
    </nsd:repoContext>
  </nsd:metadata>

  <!-- ========================================
       2️⃣ IMPACT ANALYSIS (Obrigatório - CRÍTICO)
       Esta seção é a mais importante para prevenir conflitos
       ======================================== -->
  <nsd:impactAnalysis>
    <nsd:summary>{{DESCRIVE_OVERALL_IMPACT}}</nsd:summary>

    <!-- Arquivos que serão modificados -->
    <nsd:affectedFiles>
      <nsd:file type="map" action="modify">{{FRONTEND/data/MapXXX.json}}</nsd:file>
      <nsd:file type="common_event" action="modify">{{FRONTEND/data/CommonEvents.json}}</nsd:file>
      <nsd:file type="plugin" action="create">{{FRONTEND/js/plugins/Coreto_XXX.js}}</nsd:file>
      <nsd:file type="other" action="">{{OTHER_FILES}}</nsd:file>
    </nsd:affectedFiles>

    <!-- Análise detalhada de cada mapa afetado -->
    <nsd:mapAnalysis mapId="{{MAP_ID}}" mapName="{{MAP_NAME}}">
      <!-- VARIÁVEIS EXISTENTES NO MAPA -->
      <nsd:existingVariables>
        <nsd:variable id="{{ID}}" name="{{NAME}}">
          <nsd:description>{{OQUE_FAZ}}</nsd:description>
          <nsd:usedBy>{{QUEST/SYSTEM_NAME}}</nsd:usedBy>
          <nsd:valueRange>{{MIN-MAX}}</nsd:valueRange>
          <nsd:riskLevel>none|low|medium|high|critical</nsd:riskLevel>
          <nsd:notes>{{NOTAS}}</nsd:notes>
        </nsd:variable>
      </nsd:existingVariables>

      <!-- SWITCHES EXISTENTES NO MAPA -->
      <nsd:existingSwitches>
        <nsd:switch id="{{ID}}" name="{{NAME}}">
          <nsd:description>{{OQUE_FAZ}}</nsd:description>
          <nsd:usedBy>{{QUEST/SYSTEM_NAME}}</nsd:usedBy>
          <nsd:riskLevel>none|low|medium|high|critical</nsd:riskLevel>
          <nsd:notes>{{NOTAS}}</nsd:notes>
        </nsd:switch>
      </nsd:existingSwitches>

      <!-- EVENTOS CRÍTICOS EXISTENTES -->
      <nsd:criticalEvents>
        <nsd:event id="{{EVENT_ID}}" name="{{EVENT_NAME}}">
          <nsd:location x="{{X}}" y="{{Y}}"/>
          <nsd:trigger>{{ACTION_BUTTON|PLAYER_TOUCH|EVENT_TOUCH|AUTORUN|PARALLEL}}</nsd:trigger>
          <nsd:pages>
            <nsd:page number="{{PAGE_NUMBER}}">
              <nsd:conditions>{{CONDITIONS}}</nsd:conditions>
              <nsd:criticalBehavior>{{OQUE_FAZ_E_PORQUE_NAO_PODE_SER_QUEBRADO}}</nsd:criticalBehavior>
            </nsd:page>
          </nsd:pages>
          <nsd:mustRemainFunctional>true|false</mustRemainFunctional>
        </nsd:event>
      </nsd:criticalEvents>

      <!-- COMMON EVENTS CHAMADOS POR EVENTOS DO MAPA -->
      <nsd:existingCommonEventCalls>
        <nsd:call eventId="{{EVENT_ID}}" commonEventId="{{CE_ID}}">
          <nsd:description>{{DESCRICAO}}</nsd:description>
          <nsd:risks>{{RISCOS_DE_MODIFICAR_OU_SOBRESCREVER}}</nsd:risks>
        </nsd:call>
      </nsd:existingCommonEventCalls>

      <!-- SELF-SWITCHES EM USO -->
      <nsd:existingSelfSwitches>
        <nsd:selfSwitch eventId="{{EVENT_ID}}" switch="{{A|B|C|D}}">
          <nsd:purpose>{{PROPÓSITO}}</nsd:purpose>
          <nsd:risks>{{RISCOS}}</nsd:risks>
        </nsd:selfSwitch>
      </nsd:existingSelfSwitches>

      <!-- ANÁLISE DE PERFORMANCE DO MAPA -->
      <nsd:performanceAnalysis>
        <nsd:parallelProcessCount>{{COUNT}}</nsd:parallelProcessCount>
        <nsd:complexMoveRoutes>{{COUNT}}</nsd:complexMoveRoutes>
        <nsd:riskOfLag>none|low|medium|high</nsd:riskOfLag>
        <nsd:recommendations>{{RECOMENDAÇOES}}</nsd:recommendations>
      </nsd:performanceAnalysis>
    </nsd:mapAnalysis>

    <!-- RISCOS IDENTIFICADOS -->
    <nsd:identifiedRisks>
      <nsd:risk id="{{RISK_ID}}" severity="critical|high|medium|low">
        <nsd:description>{{DESCRICAO_DO_RISCO}}</nsd:description>
        <nsd:impact>{{OQUE_PODE_ACONTECER}}</nsd:impact>
        <nsd:mitigation>{{COMO_EVITAR}}</mitigation>
      </nsd:risk>
    </nsd:identifiedRisks>
  </nsd:impactAnalysis>

  <!-- ========================================
       3️⃣ IMPLEMENTATION PLAN (Obrigatório)
       ======================================== -->
  <nsd:implementationPlan>
    <!-- GERENCIAMENTO DE ESTADO -->
    <nsd:stateManagement>
      <!-- NOVAS VARIÁVEIS -->
      <nsd:newVariables>
        <nsd:variable id="{{ID}}" name="{{NAME}}">
          <nsd:purpose>{{PROPÓSITO}}</nsd:purpose>
          <nsd:scope>{{QUEST/SYSTEM/GLOBAL}}</nsd:scope>
          <nsd:valueRange>{{MIN-MAX}}</nsd:valueRange>
          <nsd:defaultValue>{{DEFAULT}}</nsd:defaultValue>
          <nsd:states>
            <nsd:state value="{{VALUE}}">{{SIGNIFICA}}</nsd:state>
          </nsd:states>
        </nsd:variable>
      </nsd:newVariables>

      <!-- NOVOS SWITCHES -->
      <nsd:newSwitches>
        <nsd:switch id="{{ID}}" name="{{NAME}}">
          <nsd:purpose>{{PROPÓSITO}}</nsd:purpose>
          <nsd:scope>{{QUEST/SYSTEM/GLOBAL}}</nsd:scope>
        </nsd:switch>
      </nsd:newSwitches>

      <!-- MUDANÇAS TEMPORÁRIAS NO PARTY -->
      <nsd:temporaryPartyChanges>
        <!-- Adicionar membros temporariamente ao grupo -->
        <nsd:addAction actorId="{{ACTOR_ID}}" actorName="{{NAME}}">
          <nsd:purpose>{{PORQUE_ADICIONAR}}</nsd:purpose>
          <nsd:removeCondition>{{QUANDO_REMOVER}}</nsd:removeCondition>
        </nsd:addAction>
        <!-- Remover membros temporariamente do grupo -->
        <nsd:removeAction actorId="{{ACTOR_ID}}" actorName="{{NAME}}">
          <nsd:purpose>{{PORQUE_REMOVER}}</nsd:purpose>
          <nsd:restoreCondition>{{QUANDO_RESTAURAR}}</nsd:restoreCondition>
        </nsd:removeAction>
      </nsd:temporaryPartyChanges>

      <!-- ESTADO DO PLAYER -->
      <nsd:playerState>
        <nsd:controlRemoved>
          <nsd:when>{{QUANDO}}</nsd:when>
          <nsd:method>{{METHOD}}</nsd:method>
          <nsd:restored>{{QUANDO_E_COMO}}</nsd:restored>
        </nsd:controlRemoved>
        <nsd:transparency>
          <nsd:changed>true|false</nsd:changed>
          <nsd:restored>{{COMO}}</nsd:restored>
        </nsd:transparency>
      </nsd:playerState>

      <!-- SOBRESCRITAS DE AMBIENTE -->
      <nsd:environmentOverrides>
        <!-- Mudanças temporárias no ambiente do mapa -->
        <nsd:override type="parallax|bgm|bgs|battleback|tileset">
          <nsd:property>{{PROPERTY_NAME}}</nsd:property>
          <nsd:newValue>{{NEW_VALUE}}</nsd:newValue>
          <nsd:originalValue>{{ORIGINAL_VALUE}}</nsd:originalValue>
          <nsd:restoreMethod>{{COMO_RESTAURAR}}</nsd:restoreMethod>
        </nsd:override>
      </nsd:environmentOverrides>

      <!-- SETUP DA CENA -->
      <nsd:stateSetup>
        <nsd:preConditions>
          <nsd:condition type="variable|switch|item|actor">
            <nsd:target>{{ID}}</nsd:target>
            <nsd:operator>{{==|!=|>|<|>=|<=}}</nsd:operator>
            <nsd:value>{{VALUE}}</nsd:value>
            <nsd:description>{{DESCRICAO}}</nsd:description>
          </nsd:condition>
        </nsd:preConditions>
        <nsd:execution>
          <nsd:step sequence="{{N}}">{{ACAO}}</nsd:step>
        </nsd:execution>
      </nsd:stateSetup>

      <!-- TEARDOWN DA CENA (ESSENCIAL!) -->
      <nsd:stateTeardown>
        <nsd:triggers>
          <nsd:trigger>{{QUANDO_A_CENA_TERMINA}}</nsd:trigger>
        </nsd:triggers>
        <nsd:execution>
          <nsd:step sequence="{{N}}">{{ACAO_DE_LIMPEZA}}</nsd:step>
          <!-- Ações de teardown DEVEM incluir:
               - Desligar switches de cena ativa
               - Limpar variáveis temporárias
               - Resetar self-switches usados na cena
               - Retornar eventos às posições originais (se movidos)
               - Restaurar controle do player
               - Restaurar party (se modificado)
               - Restaurar ambiente (BGM/BGS/Parallax/etc)
          -->
        </nsd:execution>
        <nsd:abortHandling>
          <nsd:description>{{OQUE_ACONTECE_SE_O_JOGADOR_SAIR_DURANTE_CENA}}</nsd:description>
        </nsd:abortHandling>
      </nsd:stateTeardown>
    </nsd:stateManagement>

    <!-- ESPECIFICAÇÃO DE EVENTOS -->
    <nsd:eventSpecification mapId="{{MAP_ID}}">
      <nsd:event id="{{EVENT_ID}}" name="{{EVENT_NAME}}">
        <nsd:page number="{{PAGE_NUM}}">
          <nsd:conditions>
            <nsd:switch id="{{ID}}" value="{{ON|OFF}}"/>
            <nsd:variable id="{{ID}}" operator="{{OP}}" value="{{VAL}}"/>
            <nsd:selfSwitch switch="{{A|B|C|D}}" value="{{ON|OFF}}"/>
          </nsd:conditions>
          <nsd:location x="{{X}}" y="{{Y}}"/>
          <nsd:trigger>{{ACTION_BUTTON|PLAYER_TOUCH|EVENT_TOUCH|AUTORUN|PARALLEL}}</nsd:trigger>
          <nsd:graphic>
            <nsd:type>{{CHARACTER|TILE|NONE}}</nsd:type>
            <nsd:file>{{FILE_PATH}}</nsd:file>
            <nsd:index>{{INDEX}}</nsd:index>
          </nsd:graphic>
          <nsd:movement>
            <nsd:type>{{FIXED|RANDOM|BY_ROUTE}}</nsd:type>
            <nsd:speed>{{SPEED}}</nsd:speed>
            <nsd:freq>{{FREQ}}</nsd:freq>
          </nsd:movement>
          <nsd:commands>
            <nsd:commandLine>{{LISTA_DE_COMANDOS}}</nsd:commandLine>
          </nsd:commands>
          <!-- SELF-SWITCHES USADOS POR ESTE EVENTO -->
          <nsd:selfSwitches>
            <nsd:selfSwitch id="{{A|B|C|D}}" purpose="{{PROPÓSITO}}"/>
          </nsd:selfSwitches>
          <nsd:notes>{{NOTAS_IMPLEMENTACAO}}</nsd:notes>
        </nsd:page>
      </nsd:event>
    </nsd:eventSpecification>
            <nsd:state value="{{VALUE}}">{{SIGNIFICA}}</nsd:state>
          </nsd:states>
        </nsd:variable>
      </nsd:newVariables>

      <!-- NOVOS SWITCHES -->
      <nsd:newSwitches>
        <nsd:switch id="{{ID}}" name="{{NAME}}">
          <nsd:purpose>{{PROPÓSITO}}</nsd:purpose>
          <nsd:scope>{{QUEST/SYSTEM/GLOBAL}}</nsd:scope>
        </nsd:switch>
      </nsd:newSwitches>

      <!-- ESTADO DO PLAYER -->
      <nsd:playerState>
        <nsd:controlRemoved>
          <nsd:when>{{QUANDO}}</nsd:when>
          <nsd:method>{{METHOD}}</nsd:method>
          <nsd:restored>{{QUANDO_E_COMO}}</nsd:restored>
        </nsd:controlRemoved>
        <nsd:transparency>
          <nsd:changed>true|false</nsd:changed>
          <nsd:restored>{{COMO}}</nsd:restored>
        </nsd:transparency>
      </nsd:playerState>

      <!-- SETUP DA CENA -->
      <nsd:stateSetup>
        <nsd:preConditions>
          <nsd:condition type="variable|switch|item|actor">
            <nsd:target>{{ID}}</nsd:target>
            <nsd:operator>{{==|!=|>|<|>=|<=}}</nsd:operator>
            <nsd:value>{{VALUE}}</nsd:value>
            <nsd:description>{{DESCRICAO}}</nsd:description>
          </nsd:condition>
        </nsd:preConditions>
        <nsd:execution>
          <nsd:step sequence="{{N}}">{{ACAO}}</nsd:step>
        </nsd:execution>
      </nsd:stateSetup>

      <!-- TEARDOWN DA CENA (ESSENCIAL!) -->
      <nsd:stateTeardown>
        <nsd:triggers>
          <nsd:trigger>{{QUANDO_A_CENA_TERMINA}}</nsd:trigger>
        </nsd:triggers>
        <nsd:execution>
          <nsd:step sequence="{{N}}">{{ACAO_DE_LIMPEZA}}</nsd:step>
          <!-- Exemplos de ações de teardown:
               - Desligar switch de cena ativa
               - Limpar variáveis temporárias
               - Resetar self-switches
               - Retornar eventos às posições originais
               - Restaurar controle do player
               - Restaurar BGM/BGS
          -->
        </nsd:execution>
        <nsd:abortHandling>
          <nsd:description>{{OQUE_ACONTECE_SE_O_JOGADOR_SAIR_DURANTE_CENA}}</nsd:description>
        </nsd:abortHandling>
      </nsd:stateTeardown>
    </nsd:stateManagement>

    <!-- ESPECIFICAÇÃO DE EVENTOS -->
    <nsd:eventSpecification mapId="{{MAP_ID}}">
      <nsd:event id="{{EVENT_ID}}" name="{{EVENT_NAME}}">
        <nsd:page number="{{PAGE_NUM}}">
          <nsd:conditions>
            <nsd:switch id="{{ID}}" value="{{ON|OFF}}"/>
            <nsd:variable id="{{ID}}" operator="{{OP}}" value="{{VAL}}"/>
            <nsd:selfSwitch switch="{{A|B|C|D}}" value="{{ON|OFF}}"/>
          </nsd:conditions>
          <nsd:location x="{{X}}" y="{{Y}}"/>
          <nsd:trigger>{{ACTION_BUTTON|PLAYER_TOUCH|EVENT_TOUCH|AUTORUN|PARALLEL}}</nsd:trigger>
          <nsd:graphic>
            <nsd:type>{{CHARACTER|TILE|NONE}}</nsd:type>
            <nsd:file>{{FILE_PATH}}</nsd:file>
            <nsd:index>{{INDEX}}</nsd:index>
          </nsd:graphic>
          <nsd:movement>
            <nsd:type>{{FIXED|RANDOM|BY_ROUTE}}</nsd:type>
            <nsd:speed>{{SPEED}}</nsd:speed>
            <nsd:freq>{{FREQ}}</nsd:freq>
          </nsd:movement>
          <nsd:commands>
            <nsd:commandLine>{{LISTA_DE_COMANDOS}}</nsd:commandLine>
          </nsd:commands>
          <nsd:notes>{{NOTAS_IMPLEMENTACAO}}</nsd:notes>
        </nsd:page>
      </nsd:event>
    </nsd:eventSpecification>

    <!-- REQUISITOS DE ASSETS -->
    <nsd:assetRequirements>
      <nsd:assets>
        <nsd:asset type="character|picture|bgm|bgs|se|animation|movie">
          <nsd:file>{{FILE_PATH}}</nsd:file>
          <nsd:purpose>{{PROPÓSITO}}</nsd:purpose>
          <nsd:status>existing|new|modified</nsd:status>
        </nsd:asset>
      </nsd:assets>
    </nsd:assetRequirements>

    <!-- INTERAÇÕES COM PLUGINS -->
    <nsd:pluginInteractions>
      <nsd:interaction plugin="{{PLUGIN_NAME}}">
        <nsd:command>{{COMANDO}}</nsd:command>
        <nsd:parameters>
          <nsd:param name="{{NAME}}">{{VALUE}}</nsd:param>
        </nsd:parameters>
        <nsd:purpose>{{PROPÓSITO}}</nsd:purpose>
      </nsd:interaction>
    </nsd:pluginInteractions>

    <!-- COMMON EVENTS -->
    <nsd:commonEventSpecification>
      <nsd:commonEvent id="{{CE_ID}}" name="{{NAME}}">
        <nsd:trigger>{{NONE|AUTORUN|PARALLEL}}</nsd:trigger>
        <nsd:commands>
          <nsd:commandLine>{{LISTA_DE_COMANDOS}}</nsd:commandLine>
        </nsd:commands>
        <nsd:notes>{{NOTAS}}</nsd:notes>
      </nsd:commonEvent>
    </nsd:commonEventSpecification>
  </nsd:implementationPlan>

  <!-- ========================================
       4️⃣ SAVE/LOAD CONSIDERATIONS (Obrigatório se aplicável)
       ======================================== -->
  <nsd:saveLoadConsiderations>
    <nsd:saveAllowed>true|false</nsd:saveAllowed>
    <nsd:notes>{{NOTAS_SOBRE_O_QUE_ACONTECE_AO_SALVAR_DURANTE_CENA}}</nsd:notes>
    <nsd:loadBehavior>{{COMO_A_CENA_SE_COMPORTA_AO_CARREGAR}}</nsd:loadBehavior>
    <nsd:riskLevel>none|low|medium|high</nsd:riskLevel>
  </nsd:saveLoadConsiderations>

  <!-- ========================================
       5️⃣ VERIFICATION (Obrigatório)
       ======================================== -->
  <nsd:verification>
    <!-- CHECKLIST DE IMPLEMENTAÇÃO -->
    <nsd:implementationChecklist>
      <nsd:item id="{{ITEM_ID}}" status="todo|in_progress|done" type="pre|during|post">
        <nsd:description>{{OQUE_VERIFICAR}}</nsd:description>
        <nsd:verificationMethod>{{COMO_VERIFICAR}}</nsd:verificationMethod>
      </nsd:item>
    </nsd:implementationChecklist>

    <!-- CENÁRIOS DE TESTE -->
    <nsd:testingScenarios>
      <nsd:scenario name="{{SCENARIO_NAME}}" type="happy_path|conflict|edge_case|regression">
        <nsd:description>{{DESCRICAO}}</nsd:description>
        <nsd:steps>
          <nsd:step sequence="{{N}}">{{ACAO}}</nsd:step>
        </nsd:steps>
        <nsd:expectedResults>
          <nsd:result>{{OQUE_DEVE_ACONTECER}}</nsd:result>
        </nsd:expectedResults>
      </nsd:scenario>
    </nsd:testingScenarios>

    <!-- TESTES DE REGRESSÃO -->
    <nsd:regressionTests>
      <nsd:test target="{{QUEST/FEATURE_NAME}}">
        <nsd:reason>{{PORQUE_PRECISA_SER_TESTADO}}</nsd:reason>
        <nsd:steps>{{PASSOS}}</nsd:steps>
        <nsd:expected>{{RESULTADO_ESPERADO}}</nsd:expected>
      </nsd:test>
    </nsd:regressionTests>
  </nsd:verification>

  <!-- ========================================
       6️⃣ OUTPUTS E SIDE EFFECTS (Obrigatório)
       ======================================== -->
  <nsd:outputs>
    <nsd:output type="variable|switch|flag|quest|item">
      <nsd:name>{{NOME}}</nsd:name>
      <nsd:value>{{VALOR}}</nsd:value>
      <nsd:persistence>{{PERMANENTE|TEMPORARIO}}</persistence>
    </nsd:output>
  </nsd:outputs>

  <nsd:sideEffects>
    <nsd:effect>
      <nsd:target>{{OQUE_E_AFETADO}}</nsd:target>
      <nsd:description>{{EFEITO}</nsd:description>
    </nsd:effect>
  </nsd:sideEffects>

  <!-- ========================================
       7️⃣ NOTAS E REFERÊNCIAS (Opcional)
       ======================================== -->
  <nsd:notes>
    <nsd:note category="technical|narrative|design|performance">
      <nsd:content>{{NOTA}}</nsd:content>
      <nsd:priority>low|medium|high|critical</nsd:priority>
    </nsd:note>
  </nsd:notes>

  <nsd:references>
    <nsd:link type="document|image|video|other">
      <nsd:url>{{URL}}</nsd:url>
      <nsd:description>{{DESCRICAO}}</nsd:description>
    </nsd:link>
  </nsd:references>

  <!-- ========================================
       METADADOS DE CONTROLE
       ======================================== -->
  <nsd:controlMetadata>
    <nsd:totalEvents>{{COUNT}}</nsd:totalEvents>
    <nsd:totalCommonEvents>{{COUNT}}</nsd:totalCommonEvents>
    <nsd:totalVariables>{{COUNT}}</nsd:totalVariables>
    <nsd:totalSwitches>{{COUNT}}</nsd:totalSwitches>
    <nsd:estimatedComplexity>low|medium|high</nsd:estimatedComplexity>
    <nsd:estimatedTime>{{HOURS}}</estimatedTime>
    <nsd:dependencies>
      <nsd:dependency type="quest|system|asset">{{DESCRICAO}}</nsd:dependency>
    </nsd:dependencies>
  </nsd:controlMetadata>

</nsd:technicalAnalysis>
